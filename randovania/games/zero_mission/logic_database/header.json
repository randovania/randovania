        "tricks": {
            "WallJump": {
                "long_name": "Wall Jumps",
                "description": "By spin jumping against a wall, reversing the direction of the D-Pad, and pressing jump again, the player can perform a wall jump. Although an intentional mechanic, this technique is treated as a trick to make the randomizer more accessible.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "Shinespark": {
                "long_name": "Shinespark",
                "description": "By building a speed boost and crouching, Samus can store the Speed Booster's immense energy, and pressing the jump button allows her to release it all at once, flying through the air. Although an intentional mechanic, this technique is treated as a trick to make the randomizer more accessible.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "HeatRuns": {
                "long_name": "Heat Runs",
                "description": "Although the volcanic Norfair is perilous, it is still entirely possible to brave its heat without the Varia suit. Heat Running is the act of traversing heated rooms without protection.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "IBA": {
                "long_name": "Ice Beam Abuse",
                "description": "Using the Ice Beam to freeze enemies opens many possibilities for traversal, some unintentional. Well-placed frozen enemies can be used to reach high places or clip through thin ceilings.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "IBJ": {
                "long_name": "Infinite Bomb Jump",
                "description": "By timing bombs precisely, the player can ride their blasts to gain an infinite amount of height.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "DBoost": {
                "long_name": "Damage Boosting",
                "description": "When Samus takes damage from physical sources, like spikes and enemies, she receives a small knockback away from the enemy. However, by carefully manipulating inputs, a player can use this boost to send Samus flying across rooms.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "Movement": {
                "long_name": "Movement",
                "description": "Covers general movement skills the player can use to optimize their movement.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "Knowledge": {
                "long_name": "Knowledge",
                "description": "Covers a number of tricks which require little to no skill from the player except to know that they exist. ",
                "require_documentation_above": 0,
                "extra": {}
            },
            "Combat": {
                "long_name": "Combat",
                "description": "Encapsulates a number of more specific tricks related to combat, as well as the player's general skill in dealing damage without taking it. Dictates how many resources the player is expected to have for fights, and whether certain techniques are considered to be in logic.",
                "require_documentation_above": 0,
                "extra": {}
            },
            "MidairMorph": {
                "long_name": "Mid-Air Morphs",
                "description": "Entering Morph Ball mode while in mid air to enter 1 tile high gaps without power grip or bombs",
                "require_documentation_above": 0,
                "extra": {}
            }
        },
