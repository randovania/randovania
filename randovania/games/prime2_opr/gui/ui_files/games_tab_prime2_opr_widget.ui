  <widget class="QWidget" name="tab_intro">
   <attribute name="title">
    <string>Introduction</string>
   </attribute>
   <layout class="QVBoxLayout" name="intro_layout">
    <item>
     <layout class="QHBoxLayout" name="intro_cover_layout">
      <item>
       <widget class="QLabel" name="game_cover_label">
        <property name="text">
         <string>TextLabel</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="intro_label">
        <property name="text">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Navigate Aether and Dark Aether in search of the Sky Temple Keys, then defeat Emperor Ing and Dark Samus to win the war for the Luminoth!&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;The totems in Sky Temple Gateway can be scanned to receive hints on the locations of each Sky Temple Key. Likewise, the gates for the three Dark Temples can be scanned to receive hints on the locations of each Dark Temple Key. &lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;Luminoth Lore can be scanned for general hints, and you can optionally enable scanning Keybearer Corpses to receive a vague hint about the item in their respective Flying Ing Cache.&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;Don't forget to check out our &lt;a href=&quot;tab://FAQ&quot;&gt;Frequently Asked Questions&lt;/a&gt; and the list of &lt;a href=&quot;tab://Differences&quot;&gt;Differences&lt;/a&gt; from the vanilla game.&lt;/p&gt;&lt;p align=&quot;justify&quot;&gt;To get started, use the Quick Generate button to generate a game using the default settings!&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </item>
    <item>
     <widget class="QPushButton" name="quick_generate_button">
      <property name="text">
       <string>Quick generate</string>
      </property>
     </widget>
    </item>
    <item>
     <spacer name="intro_spacer">
      <property name="orientation">
       <enum>Qt::Orientation::Vertical</enum>
      </property>
      <property name="sizeHint" stdset="0">
       <size>
        <width>20</width>
        <height>40</height>
       </size>
      </property>
     </spacer>
    </item>
   </layout>
  </widget>
